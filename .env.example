# Formspree form ID — get this from https://formspree.io/forms after creating a form
# pointed at contact@zerrastudios.com, then copy the ID from the endpoint URL.
# Example: if your endpoint is https://formspree.io/f/xpwzgkbd, set VITE_FORMSPREE_FORM_ID=xpwzgkbd
VITE_FORMSPREE_FORM_ID=your_form_id_here
