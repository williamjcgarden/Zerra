# ---------------------------------------------------------------------------
# Zerra Studios — Environment Variables
# Copy this file to .env and fill in the values. Never commit .env.
# ---------------------------------------------------------------------------

# Base URL of the backend API (e.g. https://api.zerrastudios.com)
VITE_API_URL=

# Secret key for authenticating requests to the backend API
VITE_API_KEY=

# Contact form — email delivery service (e.g. Resend, SendGrid, Postmark)
VITE_EMAIL_SERVICE_API_KEY=
VITE_CONTACT_FORM_RECIPIENT=

# Analytics (e.g. Plausible, PostHog, Google Analytics measurement ID)
VITE_ANALYTICS_ID=

# Booking / scheduling integration (e.g. Calendly, Cal.com embed token)
VITE_BOOKING_URL=
